# ============================================================
# 프레임워크 코드만 git에 올라가도록 설정
# 프로젝트별 데이터, 모델, 실험 결과는 제외
# ============================================================

# ── 데이터 (DVC로 관리) ──────────────────────────────────────
data/images/
data/labels/
data/splits/
data/dataset.yaml          # dataset.py가 자동 생성

# ── 모델 가중치 ──────────────────────────────────────────────
models/
!models/.gitkeep
*.pt
*.pth

# ── 실험 결과 (MLflow / Optuna) ──────────────────────────────
mlflow_runs/
mlflow.db
optuna_study.db
runs/                      # Ultralytics 기본 출력

# ── DVC ──────────────────────────────────────────────────────
.dvc/cache/
.dvc/tmp/
.dvc/config                # 프로젝트별 서버 설정 (init.py가 새로 설정)
.dvc/config.local
dvc_storage/

# ── 프로젝트별 DVC 포인터 (새 프로젝트에서 직접 생성) ──────────
data/*.dvc

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
nul
